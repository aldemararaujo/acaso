<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simulador de Galton (Triângulo de Pascal Físico)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f8fafc; }
        canvas {
            max-width: 100%;
            height: auto;
            display: block;
            margin: 0 auto;
            background: #ffffff;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
        }
        #results-wrapper {
            background: #ffffff;
            border-bottom-left-radius: 12px;
            border-bottom-right-radius: 12px;
            border-top: 1px solid #f1f5f9;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .stat-col {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-left: 1px solid #f1f5f9;
            padding: 8px 0;
            font-size: 0.65rem;
        }
        .stat-col:last-child { border-right: 1px solid #f1f5f9; }
        .stat-val { font-weight: bold; color: #1e40af; }
        .stat-pct { color: #64748b; font-size: 0.6rem; }
        
        /* Estilo para os inputs numéricos pequenos */
        .number-input {
            width: 70px;
            padding: 2px 4px;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            font-size: 0.875rem;
            font-weight: 600;
            text-align: center;
            color: #1e293b;
        }
        .number-input:focus {
            outline: none;
            border-color: #3b82f6;
            ring: 1px #3b82f6;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-5xl mx-auto">
        <header class="text-center mb-8">
            <h1 class="text-3xl font-bold text-slate-900">Simulador de Galton</h1>
            <p class="text-slate-600">Visualize a distribuição de probabilidade e a relação com o Triângulo de Pascal.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- Coluna de Controles -->
            <div class="lg:col-span-1 space-y-4">
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="font-bold text-slate-800 mb-3 border-b pb-1 text-sm uppercase tracking-wider">Configurações</h2>
                    
                    <div class="space-y-4">
                        <!-- Níveis (Linhas) -->
                        <div class="flex flex-col gap-1">
                            <div class="flex justify-between items-center">
                                <label class="text-xs font-semibold text-slate-600">Níveis (1-15):</label>
                                <input type="number" id="num-rows" min="1" max="15" value="6" class="w-14 p-1 border rounded text-center font-bold text-sm outline-none focus:ring-1 focus:ring-blue-500">
                            </div>
                            <input type="range" id="input-rows" min="1" max="15" value="6" class="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-600">
                        </div>
                        
                        <!-- Total de Bolinhas -->
                        <div class="flex flex-col gap-1">
                            <div class="flex justify-between items-center">
                                <label class="text-xs font-semibold text-slate-600">Bolinhas:</label>
                                <input type="number" id="num-balls" min="2" max="5000" value="100" class="w-16 p-1 border rounded text-center font-bold text-sm outline-none focus:ring-1 focus:ring-blue-500">
                            </div>
                            <input type="range" id="input-balls" min="2" max="5000" step="1" value="100" class="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-600">
                        </div>

                        <!-- Velocidade -->
                        <div class="flex flex-col gap-1">
                            <div class="flex justify-between items-center">
                                <label class="text-xs font-semibold text-slate-600">Velocidade:</label>
                                <input type="number" id="num-speed" min="1" max="10" value="3" class="w-14 p-1 border rounded text-center font-bold text-sm outline-none focus:ring-1 focus:ring-blue-500">
                            </div>
                            <input type="range" id="input-speed" min="1" max="10" value="3" class="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-600">
                            <div class="text-[9px] text-slate-400 text-center uppercase font-bold mt-1" id="val-speed-label">Média</div>
                        </div>

                        <div class="pt-2 grid grid-cols-2 gap-2">
                            <button id="btn-start" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-1 rounded-xl transition shadow-md text-xs">
                                Lançar
                            </button>
                            <button id="btn-reset" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-2 px-1 rounded-xl transition text-xs">
                                Reiniciar
                            </button>
                        </div>
                    </div>
                </div>

                <div id="stats-summary" class="bg-blue-600 p-4 rounded-2xl shadow-lg text-white hidden">
                    <h3 class="text-blue-100 text-[10px] font-bold uppercase tracking-wider mb-1">Status</h3>
                    <div class="text-xl font-mono font-bold leading-none"><span id="balls-dropped">0</span> / <span id="balls-total">0</span></div>
                    <div class="mt-3 h-1.5 bg-blue-800 rounded-full overflow-hidden">
                        <div id="progress-bar" class="h-full bg-blue-400 transition-all duration-300" style="width: 0%"></div>
                    </div>
                </div>
            </div>

            <!-- Coluna da Animação -->
            <div class="lg:col-span-3">
                <div class="relative overflow-hidden bg-white rounded-xl">
                    <canvas id="galtonCanvas"></canvas>
                    <div id="results-wrapper" class="flex w-full overflow-x-auto">
                        <!-- Gerado via JS para alinhar com as colunas do canvas -->
                    </div>
                </div>
                
                <div class="mt-4 p-4 bg-white border border-slate-200 rounded-xl text-xs text-slate-500 italic">
                    * Cada coluna representa uma posição final, a frequência e a porcentagem são atualizadas em tempo real, facilitando a análise dos resultados obtidos.
                </div>
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('galtonCanvas');
        const ctx = canvas.getContext('2d');
        const btnStart = document.getElementById('btn-start');
        const btnReset = document.getElementById('btn-reset');
        const resultsWrapper = document.getElementById('results-wrapper');
        
        // Controles de Slider
        const inputRows = document.getElementById('input-rows');
        const inputBalls = document.getElementById('input-balls');
        const inputSpeed = document.getElementById('input-speed');
        
        // Controles Numéricos
        const numRows = document.getElementById('num-rows');
        const numBalls = document.getElementById('num-balls');
        const numSpeed = document.getElementById('num-speed');
        
        const valSpeedLabel = document.getElementById('val-speed-label');
        const ballsDroppedDisplay = document.getElementById('balls-dropped');
        const ballsTotalDisplay = document.getElementById('balls-total');
        const statsSummary = document.getElementById('stats-summary');
        const progressBar = document.getElementById('progress-bar');

        let rows = 6;
        let totalBalls = 100;
        let speedMult = 3;
        let bins = [];
        let activeBalls = [];
        let droppedCount = 0;
        let finishedCount = 0;
        let animationId = null;
        let isRunning = false;

        function resizeCanvas() {
            const container = canvas.parentElement;
            canvas.width = container.clientWidth;
            canvas.height = Math.max(400, container.clientWidth * 0.7);
            initSimulation();
        }

        window.addEventListener('resize', resizeCanvas);

        // Lógica de sincronização e atualização para Nível (Linhas)
        function updateRows(val) {
            let v = parseInt(val);
            if (v < 1) v = 1;
            if (v > 15) v = 15;
            
            rows = v;
            numRows.value = v;
            inputRows.value = v;
            
            if(!isRunning) { 
                initSimulation(); 
            }
        }
        inputRows.addEventListener('input', (e) => updateRows(e.target.value));
        numRows.addEventListener('change', (e) => updateRows(e.target.value));

        // Lógica de sincronização e atualização para Bolinhas
        function updateBalls(val) {
            let v = parseInt(val);
            if (v < 2) v = 2;
            if (v > 5000) v = 5000;
            
            totalBalls = v;
            numBalls.value = v;
            inputBalls.value = v;
            ballsTotalDisplay.textContent = v;
        }
        inputBalls.addEventListener('input', (e) => updateBalls(e.target.value));
        numBalls.addEventListener('change', (e) => updateBalls(e.target.value));

        // Lógica de sincronização e atualização para Velocidade
        function updateSpeed(val) {
            let v = parseInt(val);
            if (v < 1) v = 1;
            if (v > 10) v = 10;
            
            speedMult = v;
            numSpeed.value = v;
            inputSpeed.value = v;
            
            const labels = ["Muito Lenta", "Lenta", "Média", "Média", "Rápida", "Rápida", "Veloz", "Veloz", "Instantânea", "Máxima"];
            valSpeedLabel.textContent = labels[v - 1];
        }
        inputSpeed.addEventListener('input', (e) => updateSpeed(e.target.value));
        numSpeed.addEventListener('change', (e) => updateSpeed(e.target.value));

        function initSimulation() {
            bins = new Array(rows + 1).fill(0);
            activeBalls = [];
            droppedCount = 0;
            finishedCount = 0;
            ballsTotalDisplay.textContent = totalBalls;
            ballsDroppedDisplay.textContent = "0";
            if (progressBar) progressBar.style.width = "0%";
            renderStatsLayout();
            drawBoard();
        }

        function renderStatsLayout() {
            resultsWrapper.innerHTML = '';
            const margin = 40;
            const spacingX = (canvas.width - margin * 2) / (rows + 1);
            const sideMargin = margin;

            const leftSpacer = document.createElement('div');
            leftSpacer.style.minWidth = `${sideMargin}px`;
            resultsWrapper.appendChild(leftSpacer);

            for (let i = 0; i <= rows; i++) {
                const col = document.createElement('div');
                col.className = 'stat-col';
                col.style.minWidth = `${spacingX}px`;
                col.id = `stat-col-${i}`;
                col.innerHTML = `
                    <span class="stat-val" id="freq-${i}">0</span>
                    <span class="stat-pct" id="pct-${i}">0%</span>
                `;
                resultsWrapper.appendChild(col);
            }

            const rightSpacer = document.createElement('div');
            rightSpacer.style.minWidth = `${sideMargin}px`;
            resultsWrapper.appendChild(rightSpacer);
        }

        function updateStatsDisplay() {
            bins.forEach((val, idx) => {
                const freqEl = document.getElementById(`freq-${idx}`);
                const pctEl = document.getElementById(`pct-${idx}`);
                if (freqEl && pctEl) {
                    freqEl.textContent = val;
                    const percent = finishedCount > 0 ? ((val / finishedCount) * 100).toFixed(1) : "0";
                    pctEl.textContent = `${percent}%`;
                }
            });
        }

        function drawBoard() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const margin = 40;
            const spacingX = (canvas.width - margin * 2) / (rows + 1);
            const spacingY = (canvas.height * 0.5) / Math.max(rows, 1);
            const startX = canvas.width / 2;
            const startY = 40;

            // Pinos
            ctx.fillStyle = "#cbd5e1";
            for (let r = 0; r < rows; r++) {
                const rowWidth = r * spacingX;
                const rowStartX = startX - rowWidth / 2;
                for (let i = 0; i <= r; i++) {
                    ctx.beginPath();
                    ctx.arc(rowStartX + i * spacingX, startY + r * spacingY, 3, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            // Compartimentos
            const binTopY = startY + (rows - 0.5) * spacingY + 20;
            const binBottomY = canvas.height - 5;
            const binWidth = spacingX;
            const binStartX = margin;

            ctx.strokeStyle = "#e2e8f0";
            ctx.lineWidth = 1;
            for (let i = 0; i <= rows + 1; i++) {
                const x = binStartX + i * binWidth;
                ctx.beginPath();
                ctx.moveTo(x, binTopY);
                ctx.lineTo(x, binBottomY);
                ctx.stroke();
            }

            ctx.beginPath();
            ctx.moveTo(binStartX, binBottomY);
            ctx.lineTo(binStartX + (rows + 1) * binWidth, binBottomY);
            ctx.stroke();

            const binAreaHeight = binBottomY - binTopY - 10;
            
            bins.forEach((count, i) => {
                if (count > 0) {
                    const x = binStartX + i * binWidth + binWidth / 2;
                    // Escala dinâmica adaptada para 5000 bolinhas
                    const h = (count / (totalBalls * 0.45)) * binAreaHeight;
                    const finalH = Math.min(h + 2, binAreaHeight); 
                    
                    ctx.fillStyle = "#3b82f6";
                    ctx.beginPath();
                    ctx.roundRect(x - (binWidth * 0.35), binBottomY - finalH, binWidth * 0.7, finalH, 2);
                    ctx.fill();
                }
            });
        }

        function spawnBall() {
            if (droppedCount >= totalBalls) return;
            
            activeBalls.push({
                x: canvas.width / 2,
                y: 10,
                targetX: canvas.width / 2,
                level: -1,
                posIndex: 0,
                state: 'falling',
                color: `hsl(${210 + Math.random() * 40}, 80%, 55%)`
            });
            droppedCount++;
        }

        function updateBallsAnim() {
            const margin = 40;
            const spacingX = (canvas.width - margin * 2) / (rows + 1);
            const spacingY = (canvas.height * 0.5) / Math.max(rows, 1);
            const startX = canvas.width / 2;
            const startY = 40;
            const fallSpeed = speedMult * 0.8;

            for (let i = activeBalls.length - 1; i >= 0; i--) {
                const b = activeBalls[i];

                if (b.state === 'falling') {
                    const targetY = b.level === -1 ? startY : startY + b.level * spacingY;
                    
                    b.y += fallSpeed;
                    b.x += (b.targetX - b.x) * 0.2;

                    if (b.y >= targetY) {
                        b.y = targetY;
                        if (b.level < rows - 1) {
                            const dir = Math.random() < 0.5 ? -1 : 1;
                            b.level++;
                            b.posIndex += (dir === 1 ? 1 : 0);
                            
                            const rowWidth = b.level * spacingX;
                            const rowStartX = startX - rowWidth / 2;
                            b.targetX = rowStartX + b.posIndex * spacingX;
                        } else {
                            b.state = 'landing';
                            const binStartX = margin;
                            b.targetX = binStartX + b.posIndex * spacingX + spacingX / 2;
                        }
                    }
                } else if (b.state === 'landing') {
                    b.y += fallSpeed * 1.3;
                    b.x += (b.targetX - b.x) * 0.2;

                    if (b.y >= canvas.height - 10) {
                        bins[b.posIndex]++;
                        finishedCount++;
                        ballsDroppedDisplay.textContent = finishedCount;
                        if (progressBar) progressBar.style.width = `${(finishedCount / totalBalls) * 100}%`;
                        activeBalls.splice(i, 1);
                        updateStatsDisplay();
                    }
                }
            }
        }

        function animate() {
            if (!isRunning) return;

            // Spawn dinâmico para grandes quantidades
            const spawnBatch = speedMult > 8 ? 5 : (speedMult > 5 ? 2 : 1);
            for(let j=0; j<spawnBatch; j++) {
                if (droppedCount < totalBalls && Math.random() < (speedMult / 15)) {
                    spawnBall();
                }
            }

            const subSteps = speedMult > 6 ? 2 : 1;
            for(let s=0; s<subSteps; s++) {
                updateBallsAnim();
            }
            
            drawBoard();

            activeBalls.forEach(b => {
                ctx.beginPath();
                ctx.arc(b.x, b.y, 3.5, 0, Math.PI * 2);
                ctx.fillStyle = b.color;
                ctx.fill();
                ctx.strokeStyle = "rgba(255,255,255,0.9)";
                ctx.lineWidth = 0.5;
                ctx.stroke();
            });

            if (finishedCount >= totalBalls && activeBalls.length === 0) {
                isRunning = false;
                btnStart.disabled = false;
                btnStart.textContent = "Nova Simulação";
                return;
            }

            animationId = requestAnimationFrame(animate);
        }

        btnStart.addEventListener('click', () => {
            if (isRunning) return;
            if (finishedCount >= totalBalls) initSimulation();
            
            isRunning = true;
            btnStart.disabled = true;
            btnStart.textContent = "Simulando...";
            statsSummary.classList.remove('hidden');
            animate();
        });

        btnReset.addEventListener('click', () => {
            cancelAnimationFrame(animationId);
            isRunning = false;
            btnStart.disabled = false;
            btnStart.textContent = "Lançar Bolinhas";
            statsSummary.classList.add('hidden');
            initSimulation();
        });

        resizeCanvas();
    </script>
</body>
</html>
